{
  "manifest_version": 3,
  "name": "MarvelCDB Deck Downloader",
  "version": "1.2.0",
  "description": "Download all your MarvelCDB decks (cards, metadata, and the Markdown write-ups) as a single ZIP. Runs entirely in your browser.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Download my MarvelCDB decks",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "host_permissions": ["https://marvelcdb.com/*", "https://*.marvelcdb.com/*"],
  "content_scripts": [
    {
      "matches": ["https://marvelcdb.com/*", "https://*.marvelcdb.com/*"],
      "js": ["src/zip.js", "src/transform.js", "src/extract.js", "src/ui.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
